<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csa.assistant.mapper.PaymentMapper">

    <resultMap id="PaymentResultMap" type="com.csa.assistant.entity.PaymentEntity">
        <id column="id" property="id"/>
        <result column="payment_id" property="paymentId"/>
        <result column="order_id" property="orderId"/>
        <result column="amount" property="amount"/>
        <result column="payment_method" property="method"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="paid_time" property="paidTime"/>
        <result column="user_id" property="userId"/>
    </resultMap>

    <select id="selectByPaymentId" resultMap="PaymentResultMap">
        SELECT * FROM payments WHERE payment_id = #{paymentId}
    </select>

    <select id="selectByOrderId" resultMap="PaymentResultMap">
        SELECT * FROM payments WHERE order_id = #{orderId}
    </select>

    <select id="selectByUserId" resultMap="PaymentResultMap">
        SELECT * FROM payments WHERE user_id = #{userId}
    </select>

    <select id="selectAll" resultMap="PaymentResultMap">
        SELECT * FROM payments ORDER BY create_time DESC
    </select>

    <insert id="insert">
        INSERT INTO payments (payment_id, order_id, amount, payment_method, status, create_time, paid_time, user_id)
        VALUES (#{paymentId}, #{orderId}, #{amount}, #{method}, #{status}, #{createTime}, #{paidTime}, #{userId})
    </insert>

    <update id="update">
        UPDATE payments 
        SET status = #{status}
        <if test="paidTime != null">
            , paid_time = #{paidTime}
        </if>
        WHERE payment_id = #{paymentId}
    </update>

    <update id="updateStatus">
        UPDATE payments SET status = #{status} WHERE payment_id = #{paymentId}
    </update>

</mapper>
